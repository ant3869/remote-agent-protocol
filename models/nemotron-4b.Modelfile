FROM H:\Models\lmstudio-community\NVIDIA-Nemotron-3-Nano-4B-GGUF\NVIDIA-Nemotron-3-Nano-4B-Q8_0.gguf

# Voice-tuned for this 16GB-GPU demo: a small context keeps the whole model on
# the GPU (the stock 128K default inflates the KV cache and spills onto CPU ->
# slow), and a short num_predict caps spoken replies. Thinking models also need
# LLM_REASONING_EFFORT="none" in config.py to mute the hidden <think> monologue.
PARAMETER num_ctx 8192
PARAMETER num_predict 160
