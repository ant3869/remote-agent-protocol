# Remote Agent Protocol environment overrides
#
# Copy this file to .env and uncomment only what you need. The application has
# working defaults for every non-secret setting; this is a reference, not a
# checklist. Provider examples for the vendored Pipecat framework belong in
# its own examples and are intentionally omitted here.

# Core models and diagnostics
#DEBUG_MODE=false
#LLM_MODEL=gemma-e4b-max
#OLLAMA_HOST=http://localhost:11434
#DEFAULT_PERSONA_NAME=Jess

# --- Model presets (benchmarked with voice_probe; see voice_probe/README.md) ---
# Two knobs define a profile: LLM_MODEL is the voice/chat model (runs every
# turn) and INTENT_MODEL is the router classifier (runs only on ambiguous turns
# -- explicit commands, keyword hits, and smalltalk skip it).
#
# THE CONSTRAINT: both models are resident at once, and their LOADED footprint
# (weights + KV-cache, not the file size) must fit the GPU or Ollama swaps them
# every turn and the classifier times out. The classifier's context is capped
# (see classify_with_ollama) so it stays small; on 16GB a ~2.3GB classifier
# (qwen2.5:3b) co-resides with a 12B voice model (~10GB), but the 6GB
# gemma-e4b-aggressive does not -- it only fits beside a small (~6GB) voice.
#
# QUALITY -- 12B voice smarts + solid routing (~12.3GB loaded, the default).
#            gemma-12b-huihui replies ~0.7s; qwen2.5:3b routes at 81% on
#            voice_probe and stays resident beside it (~1s classify).
#   LLM_MODEL=gemma-12b-huihui
#   INTENT_MODEL=qwen2.5:3b
#   INTENT_TIMEOUT_SECS=2.5
#
# SNAPPY  -- fast voice + best routing (~12GB loaded). Voice reply ~0.2-0.7s;
#            gemma-e4b-aggressive routes at 92% (its 6GB fits beside the ~6GB
#            e4b voice, not beside a 12B voice).
#   LLM_MODEL=gemma-e4b-max
#   INTENT_MODEL=gemma-e4b-aggressive
#   INTENT_TIMEOUT_SECS=3.0
#
# Avoid: pairing a 12B voice model with gemma-e4b-aggressive (overflows 16GB ->
# classifier times out on every turn); gemma-12b as INTENT_MODEL (~2s/call);
# hermes-20b as a standing LLM_MODEL (~15GB). LLM_MODEL can also be set
# per-persona in data/persona_overrides.json; INTENT_MODEL is global only.

# Speech-to-text and audio devices. Blank device indices use system defaults.
#STT_ENGINE=whisper
#WHISPER_MODEL=large-v3-turbo
#WHISPER_DEVICE=cuda
#WHISPER_COMPUTE_TYPE=float16
#MIC_DEVICE_INDEX=
#SPEAKER_DEVICE_INDEX=

# Text-to-speech: kokoro (local), cartesia (cloud), or voicebox (local server).
#TTS_BACKEND=kokoro
#CARTESIA_API_KEY=
#CARTESIA_TRANSPORT=http
#VOICEBOX_BASE_URL=http://127.0.0.1:18080
#VOICEBOX_SERVER_EXE=
#VOICEBOX_DATA_DIR=
#VOICEBOX_DEFAULT_ENGINE=qwen
#VOICEBOX_DEFAULT_MODEL=1.7B
#VOICEBOX_SAMPLE_RATE=24000
#VOICEBOX_WARMUP_ENABLED=true
#VOICEBOX_WARMUP_TEXT=hi
#VOICEBOX_WARMUP_DELAY_SECS=8

# Wake word. Requires openwakeword; failures fall back to always-listening.
#WAKE_WORD_ENABLED=false
#WAKE_WORD_ENGINE=openwakeword
#WAKE_WORD_MODEL=hey_jarvis
#WAKE_WORD_THRESHOLD=0.5
#WAKE_WORD_ACTIVE_WINDOW_SECS=12
# Optional JSON model-to-persona map; unavailable local secondary models are skipped.
#WAKE_WORD_PERSONAS_JSON={"hey_jarvis":"Jarvis","hey_jess":"Jess"}
#WAKE_WORD_SWITCH_TIMEOUT_SECS=0.5

# Local semantic-memory namespace. Defaults to the current OS username.
#MEM0_USER_ID=local-user

# Delegated agent backends. Commands are JSON argument arrays; {task} is
# replaced with the request. Use a trusted launcher for remote machines.
#AGENT_BACKENDS_JSON={"openclaw":["trusted-launcher","openclaw","{task}"]}
#AGENT_MACHINES_JSON={"openclaw":"Laptop"}
#AGENT_LOCAL_MACHINE=Main PC
#AGENT_DEFAULT_BACKEND=hermes

# Agent safety, status, persistence, and timeouts.
#AGENT_CONFIRM_ENABLED=true
#AGENT_CONFIRM_LOOP_LIMIT=2
#AGENT_LLM_DELEGATE=true
#AGENT_JOB_TIMEOUT_SECS=300
#AGENT_JOB_KILL_GRACE_SECS=3
#AGENT_PROGRESS_INTERVAL_SECS=30
#AGENT_VOICE_PROGRESS_MIN_SECS=20
#AGENT_VOICE_PROGRESS_INTERVAL_SECS=60
#AGENT_COMPLETION_GRACE_SECS=2
#AGENT_HISTORY_FILE=data/jess_agent_history.json

# Loopback-only lifecycle stream: ws://127.0.0.1:8765/events
#LIFECYCLE_WS_ENABLED=true
#LIFECYCLE_WS_PORT=8765
#LIFECYCLE_WS_QUEUE_SIZE=64
#AGENT_HISTORY_MAX=100
#AGENT_WORKSPACE_DIR=data/agent_workspace
#AGENT_HOST_REPO=

# Semantic intent router. Explicit commands and keyword matches bypass it.
# See the "Model presets" block above for recommended INTENT_MODEL values;
# gemma-e4b-aggressive needs INTENT_TIMEOUT_SECS >= 3 for headroom under GPU
# contention with the voice model.
#INTENT_ROUTER_ENABLED=true
#INTENT_MODEL=llama3.2:1b
#INTENT_TIMEOUT_SECS=1.5

# Persisted GUI selection. Leave blank to always boot DEFAULT_PERSONA_NAME.
#APP_STATE_FILE=
